#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Add-on: Roundcube Webmail
# Configures Roundcube — generates config, initializes SQLite DB
# ==============================================================================

declare imap_host
declare imap_port
declare smtp_host
declare smtp_port
declare des_key
declare ingress_entry
declare extra_plugins=""
declare share_plugin_dir="/share/roundcube/plugins"
declare shared_plugin_names=""
declare shared_plugin_configs=""

bashio::log.info "Configuring Roundcube..."

imap_host=$(bashio::config 'imap_host')
imap_port=$(bashio::config 'imap_port')
smtp_host=$(bashio::config 'smtp_host')
smtp_port=$(bashio::config 'smtp_port')
ingress_entry=$(bashio::addon.ingress_entry)

# Install additional composer plugins if configured
if bashio::config.has_value 'plugins'; then
    bashio::log.info "Installing additional plugins via composer..."
    cd /var/www/roundcube || exit 1
    for plugin in $(bashio::config 'plugins'); do
        bashio::log.info "  Installing plugin: ${plugin}"
        composer require "${plugin}" --no-interaction --update-no-dev --optimize-autoloader 2>&1 \
            || bashio::log.warning "  Failed to install plugin: ${plugin}"
        # Extract short name (last segment after /) for plugins array
        short_name="${plugin##*/}"
        extra_plugins="${extra_plugins}, '${short_name}'"
    done
    cd - > /dev/null || true
fi

# Dynamic plugin loader — pick up plugins dropped into the HA shared folder by
# companion add-ons. Each subdirectory of /share/roundcube/plugins/<name>/
# becomes a Roundcube plugin IFF it contains a `.ha-plugin-ready` marker file
# written by the companion add-on after atomic provisioning. If
# <name>/config.inc.php exists it is included after the main config so
# companion add-ons can inject settings.
if [[ -d "${share_plugin_dir}" ]]; then
    bashio::log.info "Scanning ${share_plugin_dir} for shared plugins..."
    for plugin_path in "${share_plugin_dir}"/*/; do
        [[ -d "${plugin_path}" ]] || continue
        plugin_name=$(basename "${plugin_path}")
        # Skip names that contain characters we would not want to embed in PHP.
        if [[ ! "${plugin_name}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            bashio::log.warning "  Skipping plugin with unsafe name: ${plugin_name}"
            continue
        fi
        # Reject symlinked plugin dirs: /share is writable by any add-on, so a
        # symlink would let a writer point Roundcube at code outside the
        # shared-plugins root.
        if [[ -L "${plugin_path%/}" ]]; then
            bashio::log.warning "  Skipping symlinked plugin entry: ${plugin_name}"
            continue
        fi
        # Resolve to a real path and re-check containment under share_plugin_dir.
        resolved=$(realpath -q "${plugin_path%/}" || true)
        if [[ -z "${resolved}" || "${resolved}" != "${share_plugin_dir}"/* ]]; then
            bashio::log.warning "  Skipping plugin outside shared root: ${plugin_name}"
            continue
        fi
        # Require a readiness marker so we never pick up half-provisioned trees.
        if [[ ! -f "${plugin_path}.ha-plugin-ready" ]]; then
            bashio::log.info "  Skipping ${plugin_name}: no .ha-plugin-ready marker"
            continue
        fi
        target="/var/www/roundcube/plugins/${plugin_name}"
        rm -rf "${target}"
        ln -s "${resolved}" "${target}"
        bashio::log.info "  Linked shared plugin: ${plugin_name}"
        shared_plugin_names="${shared_plugin_names}, '${plugin_name}'"
        if [[ -f "${plugin_path}config.inc.php" ]]; then
            shared_plugin_configs="${shared_plugin_configs}${plugin_path}config.inc.php"$'\n'
        fi
    done
fi

# Ensure persistent data directories exist
mkdir -p /data/db

# One-shot database reset (remove flag file after reset)
if [[ -f /data/db/reset_db ]]; then
    bashio::log.warning "Database reset requested — removing roundcube.db"
    rm -f /data/db/roundcube.db /data/db/reset_db
fi

# Generate a stable DES key on first run (atomic write)
if [[ ! -f /data/des_key ]]; then
    bashio::log.info "Generating new encryption key..."
    openssl rand -base64 18 | tr -d '\n' > /data/des_key.tmp
    mv /data/des_key.tmp /data/des_key
fi
des_key=$(cat /data/des_key)

# Write Roundcube configuration
bashio::log.info "Writing Roundcube configuration..."
cat > /var/www/roundcube/config/config.inc.php <<RCEOF
<?php

// Database
\$config['db_dsnw'] = 'sqlite:////data/db/roundcube.db?mode=0640';

// IMAP
\$config['imap_host'] = '${imap_host}:${imap_port}';

// SMTP — reuse IMAP credentials
\$config['smtp_host'] = '${smtp_host}:${smtp_port}';
\$config['smtp_user'] = '%u';
\$config['smtp_pass'] = '%p';

// Security
\$config['des_key'] = '${des_key}';
\$config['enable_installer'] = false;
\$config['auto_create_user'] = true;

// Trust the HA Supervisor proxy for X-Ingress-Path and other forwarded headers
\$config['proxy_whitelist'] = ['172.30.32.2'];

// Identity — allow any From address (needed for catch-all)
\$config['identities_level'] = 0;

// Plugins — built-in defaults plus composer-installed and shared plugins
\$config['plugins'] = ['identity_select', 'archive', 'zipdownload'${extra_plugins}${shared_plugin_names}];

// identity_select — use Delivered-To header for accurate alias matching
\$config['identity_select_headers'] = ['Delivered-To', 'X-Original-To'];

// Logging — stdout routes through php-fpm's catch_workers_output to container stderr
\$config['log_driver'] = 'stdout';
\$config['per_user_logging'] = false;
\$config['smtp_log'] = false;

// UI
\$config['skin'] = 'elastic';
\$config['support_url'] = '';
\$config['product_name'] = 'Webmail';

// Ingress — set the literal base path (with trailing slash)
// Roundcube's get_request_path() strips the last path segment when reading
// from \$_SERVER headers, so we set the value directly instead.
\$config['request_path'] = '${ingress_entry}/';
RCEOF

# Append include lines for each shared plugin's config.inc.php, if present.
# Each companion add-on is responsible for writing a safe PHP file at that
# path; we only reference it here so their settings flow into Roundcube.
if [[ -n "${shared_plugin_configs}" ]]; then
    while IFS= read -r cfg; do
        [[ -n "${cfg}" ]] || continue
        # Escape any single quotes in the path before embedding as a PHP literal.
        safe_cfg=${cfg//\'/\\\'}
        cat >> /var/www/roundcube/config/config.inc.php <<PHPEOF

// Shared plugin config injected by companion add-on
@include '${safe_cfg}';
PHPEOF
        bashio::log.info "  Including shared plugin config: ${cfg}"
    done <<< "${shared_plugin_configs}"
fi

# Pipe Roundcube log files to container stderr so they appear in addon logs.
# Symlinks provide belt-and-braces: even if log_driver='stdout' is ignored for
# some code paths, file-based writes still reach the container log.
mkdir -p /var/www/roundcube/logs
for f in errors.log console.log sendmail.log; do
    rm -f "/var/www/roundcube/logs/${f}"
    ln -sf /proc/1/fd/2 "/var/www/roundcube/logs/${f}"
done

# Initialize SQLite database on first run
if [[ ! -f /data/db/roundcube.db ]]; then
    bashio::log.info "Initializing SQLite database..."
    if ! php /var/www/roundcube/bin/initdb.sh --dir=/var/www/roundcube/SQL/ 2>&1; then
        bashio::log.fatal "Database initialization failed"
        exit 1
    fi
fi

# Ensure correct permissions
chmod 0640 /data/db/roundcube.db 2>/dev/null || true
chown -R root:root /data/db

bashio::log.info "Roundcube configured."
bashio::log.info "  IMAP: ${imap_host}:${imap_port}"
bashio::log.info "  SMTP: ${smtp_host}:${smtp_port}"
