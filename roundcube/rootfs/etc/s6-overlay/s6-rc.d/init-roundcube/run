#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Add-on: Roundcube Webmail
# Configures Roundcube — generates config, initializes SQLite DB
# ==============================================================================

declare imap_host
declare imap_port
declare smtp_host
declare smtp_port
declare des_key
declare ingress_entry
declare extra_plugins=""

bashio::log.info "Configuring Roundcube..."

imap_host=$(bashio::config 'imap_host')
imap_port=$(bashio::config 'imap_port')
smtp_host=$(bashio::config 'smtp_host')
smtp_port=$(bashio::config 'smtp_port')
ingress_entry=$(bashio::addon.ingress_entry)

# Install additional composer plugins if configured
if bashio::config.has_value 'plugins'; then
    bashio::log.info "Installing additional plugins via composer..."
    cd /var/www/roundcube || exit 1
    for plugin in $(bashio::config 'plugins'); do
        bashio::log.info "  Installing plugin: ${plugin}"
        composer require "${plugin}" --no-interaction --update-no-dev --optimize-autoloader 2>&1 \
            || bashio::log.warning "  Failed to install plugin: ${plugin}"
        # Extract short name (last segment after /) for plugins array
        short_name="${plugin##*/}"
        extra_plugins="${extra_plugins}, '${short_name}'"
    done
    cd - > /dev/null || true
fi

# Ensure persistent data directories exist
mkdir -p /data/db

# One-shot database reset (remove flag file after reset)
if [[ -f /data/db/reset_db ]]; then
    bashio::log.warning "Database reset requested — removing roundcube.db"
    rm -f /data/db/roundcube.db /data/db/reset_db
fi

# Generate a stable DES key on first run (atomic write)
if [[ ! -f /data/des_key ]]; then
    bashio::log.info "Generating new encryption key..."
    openssl rand -base64 18 | tr -d '\n' > /data/des_key.tmp
    mv /data/des_key.tmp /data/des_key
fi
des_key=$(cat /data/des_key)

# Write Roundcube configuration
bashio::log.info "Writing Roundcube configuration..."
cat > /var/www/roundcube/config/config.inc.php <<RCEOF
<?php

// Database
\$config['db_dsnw'] = 'sqlite:////data/db/roundcube.db?mode=0640';

// IMAP
\$config['imap_host'] = '${imap_host}:${imap_port}';

// SMTP — reuse IMAP credentials
\$config['smtp_host'] = '${smtp_host}:${smtp_port}';
\$config['smtp_user'] = '%u';
\$config['smtp_pass'] = '%p';

// Security
\$config['des_key'] = '${des_key}';
\$config['enable_installer'] = false;
\$config['auto_create_user'] = true;

// Trust the HA Supervisor proxy for X-Ingress-Path and other forwarded headers
\$config['proxy_whitelist'] = ['172.30.32.2'];

// Identity — allow any From address (needed for catch-all)
\$config['identities_level'] = 0;

// Plugins — built-in defaults plus any composer-installed plugins
\$config['plugins'] = ['identity_select', 'archive', 'zipdownload', 'forwardemail'${extra_plugins}];

// identity_select — use Delivered-To header for accurate alias matching
\$config['identity_select_headers'] = ['Delivered-To', 'X-Original-To'];

// Logging — stdout for container/s6 integration
\$config['log_driver'] = 'stdout';
\$config['smtp_log'] = false;

// UI
\$config['skin'] = 'elastic';
\$config['support_url'] = '';
\$config['product_name'] = 'Webmail';

// Ingress — set the literal base path (with trailing slash)
// Roundcube's get_request_path() strips the last path segment when reading
// from \$_SERVER headers, so we set the value directly instead.
\$config['request_path'] = '${ingress_entry}/';
RCEOF

# Initialize SQLite database on first run
if [[ ! -f /data/db/roundcube.db ]]; then
    bashio::log.info "Initializing SQLite database..."
    php /var/www/roundcube/bin/initdb.sh \
        --dir=/var/www/roundcube/SQL/ \
        2>&1 || bashio::log.error "Database initialization failed"
fi

# Ensure correct permissions
chmod 0640 /data/db/roundcube.db 2>/dev/null || true
chown -R root:root /data/db

bashio::log.info "Roundcube configured."
bashio::log.info "  IMAP: ${imap_host}:${imap_port}"
bashio::log.info "  SMTP: ${smtp_host}:${smtp_port}"

# Debug: verify plugin installation
bashio::log.info "  Plugin dir check:"
ls -la /var/www/roundcube/plugins/forwardemail/ 2>&1 | while read line; do
    bashio::log.info "    ${line}"
done
